+        ))
+        conversation.append(FishSpeechMessage(
+            role: .user,
+            parts: [.text(FishSpeechTextPart(text: "This is a Fish S2 Pro generation test from the Swift port."))],
+            addIMStart: true,
+            addIMEnd: true,
